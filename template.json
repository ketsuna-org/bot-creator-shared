    "workflows": [
      {
        "name": "welcome_message",
        "workflowType": "event",
        "entryPoint": "main",
        "arguments": [],
        "eventTrigger": {
          "category": "members",
          "event": "guildMemberAdd"
        },
        "actions": [
          {
            "id": "action_welcome_msg",
            "type": "sendMessage",
            "enabled": true,
            "key": "welcome_sender",
            "depend_on": [],
