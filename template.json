        "data": {
          "version": 1,
          "commandType": "chatInput",
          "editorMode": "advanced",
          "executionMode": "workflow",
          "defaultMemberPermissions": "4",
          "options": [
            {
              "type": "user",
              "name": "target",
              "description": "User to ban",
              "required": true
            },
            {
              "type": "string",
              "name": "reason",
              "description": "Reason for banning",
              "required": false
            }
          ],
          "response": {
            "mode": "message",
            "text": "🔨 ((opts.target)) has been banned.",
            "type": "normal",
            "workflow": {
              "autoDeferIfActions": true,
              "visibility": "ephemeral",
              "onError": "edit_error",
              "conditional": {
                "enabled": false
              }
            }
          },
          "actions": [
            {
              "id": "action_ban",
              "type": "banUser",
              "enabled": true,
              "key": "ban_step",
              "depend_on": [],
              "error": {
                "mode": "stop"
              },
              "payload": {
                "userId": "((opts.target|userId))",
                "reason": "((opts.reason))"
              },
              "runtimeId": "action_ban"
            }
          ]
        }
